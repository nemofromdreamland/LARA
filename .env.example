# Static API key required on every request (except GET /health)
LARA_API_KEY=change-me-to-a-strong-random-secret

# LLM Provider (groq | cerebras)
LLM_PROVIDER=groq

# Groq API Key — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Cerebras API Key (fallback) — https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ChromaDB server — Docker: chroma/8000 (internal), local dev: localhost/8001
CHROMA_HOST=localhost
CHROMA_PORT=8001

# CORS origin for frontend (dev: http://localhost:5173)
FRONTEND_ORIGIN=http://localhost:5173
