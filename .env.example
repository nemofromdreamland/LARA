# This template is used in TWO places (see README "Setup"):
#   cp .env.example backend/.env   → read by the backend container (env_file)
#   cp .env.example .env           → read by docker-compose to inject
#                                    LARA_API_KEY into the frontend build
# LARA_API_KEY must be identical in both files; rotate both together and
# rebuild the frontend image.

# Static API key required on every request (except GET /health)
LARA_API_KEY=change-me-to-a-strong-random-secret

# Frontend build-time key — same value as LARA_API_KEY; Vite bakes it into the bundle
VITE_API_KEY=change-me-to-a-strong-random-secret

# LLM Provider (groq | cerebras)
LLM_PROVIDER=groq

# Groq API Key — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Cerebras API Key (fallback) — https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ChromaDB server — Docker: chroma/8000 (internal), local dev: localhost/8001
CHROMA_HOST=localhost
CHROMA_PORT=8001

# CORS origin for frontend (dev: http://localhost:5173)
FRONTEND_ORIGIN=http://localhost:5173

# Thread pool size for embedding inference (default 4).
# Each extra worker adds ~200 MB RAM; must be <= THREAD_POOL_WORKERS (default 8).
# EMBED_POOL_WORKERS=4

# Max LLM context budget in tokens (default 8192, well within llama-3.3-70b's 128K limit)
# MAX_CONTEXT_TOKENS=8192
